###  Compiler flags for fortran and C modules.


#   SGI 

PLAT = SGI

#OPT = -mips4 -O3 -OPT:Olimit=0:roundoff=3:div_split=ON:alias=typed 
OPT = -Ofast=IP27
#OPT = -trapuv -check_bounds

F77 = f77 -col120
FFLAGS_NOOPT = -O0
FFLAGS = -64 -g3 $(OPT)
CC = cc
CFLAGS = -64 -g3 $(OPT)
LINKER = f77
LINKFLAGS = -64 -g3 $(OPT)
LIBPATH = 
LAPACK =  -lcomplib.sgimath
BLAS =  
RANLIB = echo
MGS = mgs.risc
MAKE = smake
